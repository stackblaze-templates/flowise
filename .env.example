# Copy this file to .env and fill in the values before running docker compose up.
# Never commit the .env file — it is already listed in .gitignore.

# PostgreSQL credentials — change these before deploying to production
DATABASE_NAME=flowise
DATABASE_USER=flowise
DATABASE_PASSWORD=changeme_use_a_strong_password

# Flowise secret key — used to encrypt stored credentials.
# Generate a random value, e.g.: openssl rand -hex 32
FLOWISE_SECRETKEY_OVERWRITE=changeme_use_a_strong_secret_key
